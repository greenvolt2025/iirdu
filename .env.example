# =============================================================================
# RD4U Platform — Environment Configuration Example
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# Lines starting with # are comments. Do NOT commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. SUPABASE — Database & Auth
# -----------------------------------------------------------------------------
# Create a project at https://supabase.com/dashboard
# Go to: Project Settings → API → Project URL and anon key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Service role key (server-side only, NEVER expose to client)
# Go to: Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# -----------------------------------------------------------------------------
# 2. WAYFORPAY — Payment Processing (UAH/USD/EUR)
# -----------------------------------------------------------------------------
# Register at https://wayforpay.com and create a merchant account
# CRITICAL: Keep SECRET_KEY confidential!
WAYFORPAY_MERCHANT_ACCOUNT=your_merchant_account
WAYFORPAY_SECRET_KEY=your_secret_key_KEEP_SECRET

# Your domain for payment callbacks (no trailing slash)
WAYFORPAY_DOMAIN=rd4u.example.com

# -----------------------------------------------------------------------------
# 3. AI SERVICES — Report Generation
# -----------------------------------------------------------------------------
# Anthropic Claude API — primary AI for scientific reports
# Get key at: https://console.anthropic.com/settings/keys
# CRITICAL: Keep this key secret!
ANTHROPIC_API_KEY=sk-ant-api03-your-claude-api-key-here

# Google Cloud Vision API (optional) — for OCR on images
# Get key at: https://console.cloud.google.com/apis/credentials
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# -----------------------------------------------------------------------------
# 4. SIMPLEX CHAT — E2E Encrypted Document Transfer (Optional)
# -----------------------------------------------------------------------------
# SimpleX Chat CLI must be running locally with WebSocket API enabled:
#   simplex-chat -p 5225
# Docs: https://simplex.chat/docs/cli.html
SIMPLEX_WS_URL=ws://localhost:5225
SIMPLEX_RECEIVER_CONTACT=iirdu-receiver

# -----------------------------------------------------------------------------
# 5. FILE UPLOAD & STORAGE
# -----------------------------------------------------------------------------
# Local directory for temporary file storage before processing
# Ensure this directory exists and has write permissions
# IMPORTANT: Must be absolute path, no ../ allowed
UPLOAD_DIR=/var/www/rd4u/uploads

# Maximum file size in MB (default: 50)
UPLOAD_MAX_SIZE_MB=50

# -----------------------------------------------------------------------------
# 6. EMAIL (SMTP)
# -----------------------------------------------------------------------------
# SMTP server configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_NAME=МІВРУ
SMTP_FROM_EMAIL=noreply@rd4u.example.com

# -----------------------------------------------------------------------------
# 7. APPLICATION
# -----------------------------------------------------------------------------
# Public URL of the deployed website (used in emails, invoices, callbacks)
NEXT_PUBLIC_APP_URL=https://rd4u.example.com

# Default locale: "uk" (Ukrainian) or "en" (English)
NEXT_PUBLIC_DEFAULT_LOCALE=uk

# -----------------------------------------------------------------------------
# 8. OLLAMA — Local AI Model (Desktop Integration)
# -----------------------------------------------------------------------------
# Ollama must be running locally with rd4u-expert model
# Desktop app runs Ollama at this URL
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=rd4u-expert:v2

# -----------------------------------------------------------------------------
# 9. SECURITY (Optional)
# -----------------------------------------------------------------------------
# JWT secret for session encryption (generate with: openssl rand -base64 32)
# CRITICAL: Keep this secret!
JWT_SECRET=your-random-jwt-secret-here

# Rate limiting configuration (requests per hour)
RATE_LIMIT_REPORTS=5
RATE_LIMIT_UPLOADS=10
RATE_LIMIT_PAYMENTS=3
